   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Predictions for separate features "
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "- separate train / test sets "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Helper Functions "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from Tools import CaseNamer, Plotting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "FileNames = CaseNamer(\n",
    "    CASE, MODEL,\n",
    "    CUTOFF=CUT_OFF, EMODE=E_MODE, CRITERION=C_RITERION, SEARCHMODE=SEARCH_MODE, TARGET=TARGET\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Load Features"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load briefsummary and its features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "BS = StructSummaryParser().BriefSummary\n",
    "Features = Featurizer(BS)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load the BOP for the selected case"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "BOPCOEF_FILE = f'CRCOW_{CASE}_NSC_{MODEL}_{CUT_OFF}_{E_MODE}_{MOMENTS}.pkl'\n",
    "BopfoxFeatures = pd.read_pickle(BOPCOEF_FILE)\n",
    "BopfoxFeatures.drop(columns=['NSC_U_bond_atom_list'], inplace=True)\n",
    "#BopfoxFeatures.drop(columns=['NSC_U_bind'], inplace=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## clean features: reduntandly convert all features to float and mean across sites"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "BopfoxFeatures.dropna(how='any',inplace=True)\n",
    "M = BopfoxFeatures['NSC_moments'].map(lambda M: np.array(M).mean(axis=0))\n",
    "S = BopfoxFeatures['NSC_SIGMA'].map(lambda M: np.array(M).mean(axis=0))\n",
    "Binf=BopfoxFeatures['NSC_Binf'].map(lambda s: [float(si) for si in s]).map(np.mean)\n",
    "Ainf=BopfoxFeatures['NSC_Ainf'].map(lambda s: [float(si) for si in s]).map(np.mean)\n",
    "AN = BopfoxFeatures['NSC_an'].map(lambda M: np.array(M).mean(axis=0))\n",
    "BN = BopfoxFeatures['NSC_bn'].map(lambda M: np.array(M).mean(axis=0))\n",
    "Mag = Features.MagFeature[BopfoxFeatures.index]\n",
    "BOP_atom_average = pd.concat([BopfoxFeatures['NSC_U_bind'],M, S, AN, BN, Ainf, Binf, Mag], axis=1)\n",
    "# Feature Transformation to concatenation\n",
    "BOP, names = stackdata(BOP_atom_average, BOP_atom_average.columns.values)\n",
    "BOP = pd.DataFrame(data=BOP, columns=names, index = BOP_atom_average.index)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## define the column names by type of feature"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "allcolumns = BOP.columns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "columns_Mag =BOP.columns[BOP.columns.str.contains('MagConfig')]\n",
    "columns_U =BOP.columns[BOP.columns.str.contains('U_bind')]\n",
    "columns_bn = BOP.columns[BOP.columns.str.contains('bn')]\n",
    "columns_sigma =BOP.columns[BOP.columns.str.contains('SIGMA')] \n",
    "columns_moments = BOP.columns[BOP.columns.str.contains('moment')]\n",
    "columns_an = BOP.columns[BOP.columns.str.contains('an')]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "skip"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "feature_titles = pd.Series(\n",
    "    HF.cleanfeaturenames([ s.replace('NSC_','').replace('MagConfig_0','MagConfig').replace('bind_0','bind') for s in allcolumns ]), index=allcolumns\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "real_feature = HF.get_useful_features(BOP, allcolumns)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def colsgroup(kind):\n",
    "    return [ f for f in real_feature if kind in f] "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "useful = {f: colsgroup(f) for f in ['an','bn','moment','SIGMA', 'U_bind','MagConfig']}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    },
    "tags": []
   },
   "source": [
    "# Targets"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "$ \\Delta E_F  = \\dfrac{1}{N_{atoms}} \\left( E_{Total} - \\sum _{i} N_i E_i \\right) $"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "fragment"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "groundstates=Features.get_ground_states_energies()\n",
    "BS['EF'] = Features.get_formation_energy(ground_states_dic=groundstates)\n",
    "BS = BS.dropna()\n",
    "DATA = BOP.copy()\n",
    "DATA[['B0','V0','EF','E0']]=BS[['B0','V0','EF','E0']]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Distribution of targets"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### $E_{F}$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Out_In_First = DATA[~((DATA['EF']>-1) & (DATA['EF']<2))]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA = DATA[(DATA['EF'] > -1) & (DATA['EF']< 2)]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### $E_0$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA = DATA[(DATA['E0']>-100) & (DATA['E0']<10)]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA.shape"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## B0"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA = DATA[(DATA['B0'])>0 & (DATA['B0']<500)]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## V0"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA = DATA[DATA['V0']<50]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA.shape"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "skip"
    },
    "tags": []
   },
   "source": [
    "## Drop Nans !"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA.dropna(how='any', axis=0,inplace=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    },
    "tags": []
   },
   "source": [
    "# Classification and weighting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "from BopFoxFeaturizer.struct_db import struct_db\n",
    "#struct_db = SourceFileLoader('struct_db','BopFoxFeaturizer/struct_db.py').load_module().struct_db\n",
    "strucdic = struct_db().strucstrings\n",
    "\n",
    "Target_Class = pd.Series(\n",
    "    DATA.index.str.split('.').map(lambda l: l[1]).map(lambda s: s.split('-')[0]),\n",
    "    index=DATA.index\n",
    ")\n",
    "Target_Class[Target_Class.map(lambda s: s in strucdic['list.hcp'])]='hcp'\n",
    "Target_Class[Target_Class.map(lambda s: s in strucdic['list.fcc'])]='fcc'\n",
    "Target_Class[Target_Class.map(lambda s: s in strucdic['list.bcc'])]='bcc'\n",
    "Target_Class[Features.Struc == 'hcp'] = 'hcp'\n",
    "Target_Class[Features.Struc == 'bcc'] = 'bcc'\n",
    "Target_Class[Features.Struc == 'fcc'] = 'fcc'\n",
    "Target_Class[Features.Struc.str.contains('SQS-fcc')] = 'fcc'\n",
    "Target_Class[Features.Struc.str.contains('SQS-L12')] = 'fcc'\n",
    "Target_Class[Features.Struc.str.contains('sigma_')] = 'sigma'\n",
    "\n",
    "Target_Class[    \n",
    "    Target_Class.str.contains('Al42W') |\\\n",
    "    Target_Class.str.contains('Al9Co2') |\\\n",
    "    Target_Class.str.contains('Al5W') |\\\n",
    "    Target_Class.str.contains('Al12W') |\\\n",
    "    Target_Class.str.contains('Al4W') |\\\n",
    "    Target_Class.str.contains('Al5Co2')\n",
    "] = 'others'\n",
    "\n",
    "plt.hist(Target_Class, bins=80, density = True, width=0.5, align='left', color = 'purple')\n",
    "plt.xticks(rotation=90); yticks = plt.yticks([])\n",
    "plt.ylabel('')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "source": [
    "## Class Weights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "fragment"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "Classes = pd.DataFrame(Target_Class.values, columns=['Class'], index=DATA.index)\n",
    "Target_Class_Count = Target_Class.value_counts()\n",
    "Classes['Weights'] = 1/(Target_Class_Count[Target_Class]/Target_Class_Count.sum()).values #Target_Class_Count.sum()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "data_w_classes =pd.concat([DATA,Classes['Class'].loc[DATA.index]], axis=1) "
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    },
    "tags": []
   },
   "source": [
    "# Finally some Machine Learning"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "source": [
    "[![scikit-logo](https://scikit-learn.org/stable/_static/scikit-learn-logo-small.png#background-color:\"#FFFFFF\")](https://scikit-learn.org/stable/) is a standard tool for machine learning in python. The documentation in their webpage is often a good refference for tutorials, methods and Theory of Machine Learning. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "fragment"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "from sklearn.tree import DecisionTreeRegressor, plot_tree\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import mean_squared_error\n",
    "from math import sqrt\n",
    "from sklearn.metrics import r2_score\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.svm import SVR\n",
    "from sklearn.inspection import permutation_importance\n",
    "from sklearn.gaussian_process import GaussianProcessRegressor\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "from sklearn.linear_model import Lasso"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Feature Selection "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.feature_selection import  (RFECV, \n",
    "    SelectKBest, \n",
    "    SequentialFeatureSelector,\n",
    "    mutual_info_regression\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import GridSearchCV"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Helper Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "def plot_the_errors(THISERRORS,thecase):\n",
    "    alltheclases = np.unique(Classes['Class'])\n",
    "    thebadclasses = ['hcp', 'bcc', 'fcc','others','delta','R','C15']\n",
    "    thegoodclases = [c for c in alltheclases if c not in thebadclasses ]\n",
    "    fig, ax = plt.subplots(len(thegoodclases),1, sharex=True, figsize =(10,2*len(thegoodclases)))\n",
    "    for i, classes in enumerate(thegoodclases) :\n",
    "        thiserrors = np.abs(THISERRORS[Classes['Class']==classes])\n",
    "        e = ax[i].hist (thiserrors, density=False, bins=100, label=classes)\n",
    "        ax[i].annotate(classes, (0.8,0.5),xycoords = 'axes fraction', fontsize=20)\n",
    "#    ax[-1].set_xlim([-0.01,1.0])\n",
    "    ax[-1].set_ylabel('Density Counts',y=4), plt.xlabel('$|  E_F^{predicted} -  E_F^{True} | $')\n",
    "    fig.tight_layout()\n",
    "    fig.savefig(FileNames.get_plot_filename('Errors_by_class', thecase))\n",
    "#    fig.savefig('graphs/Errors_by_class_{}_{}_{}_{}.pdf'.format(case, CASE, MODEL, CUTOFF))\n",
    "    \n",
    "\n",
    "def plot_the_prediction_line(theprediction, thepredictionovertest, thecase):\n",
    "    fig, ax = plt.subplots()\n",
    "    ax.plot(theprediction, DATA[TARGET],'o', label='full dataset')\n",
    "    ax.plot(thepredictionovertest, Y_test,'o', label='test set')\n",
    "    ax.plot(DATA[TARGET], DATA[TARGET],'-k')\n",
    "    ax.legend()\n",
    "    ax.set_xlabel('True')# $\\Delta E_F$')\n",
    "    ax.set_ylabel('predicted')# $\\Delta E_F$')\n",
    "    fig.savefig(FileNames.get_plot_filename('Predictionline',thecase))\n",
    "#    fig.savefig('graphs/predictionline_{}_{}.pdf'.format(themodel,CASE, MODEL, CUTOFF))\n",
    "\n",
    "def train_test_errors(themodel, Xtrain, Xtest, Ytrain, Ytest):\n",
    "    Ypredict_train = themodel.predict(Xtrain)\n",
    "    Ypredict_test = themodel.predict(Xtest)\n",
    "    return {'train': mean_squared_error(Ytrain, Ypredict_train ,squared=False), 'test':  mean_squared_error(Ytest, Ypredict_test,squared=False )}\n",
    "\n",
    "def make_simple_pipe(model, with_scaler = True):\n",
    "        if with_scaler:\n",
    "            return Pipeline([('scaler',MinMaxScaler()),('regressor', model())])\n",
    "        else:\n",
    "            return Pipeline([('regressor', model())])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, w_train, w_test,  Y_train, Y_test = train_test_split(DATA[real_feature],Classes['Weights'], DATA[TARGET],test_size=0.2, shuffle=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "I need Lists of errors to compare methods"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses = {}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "I also need to remove targets from feature names"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "source": [
    "## simple regressor - random forest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model = make_simple_pipe(RandomForestRegressor)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model.fit(X_train,Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses['random forest regressor'] = train_test_errors(simple_model, X_train, X_test,Y_train, Y_test)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model_noscaler = make_simple_pipe(RandomForestRegressor, with_scaler=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model_noscaler.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses['random forest regressor noscale'] = train_test_errors(simple_model_noscaler, X_train, X_test, Y_train, Y_test)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.plot(simple_model.predict(X_train),Y_train,'o')\n",
    "#plt.plot(simple_model_noscaler.predict(X_train),Y_train,'o')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "fragment"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "plt.bar(['test split','train split'],[mses['random forest regressor']['test'], mses['random forest regressor']['train']])\n",
    "label = plt.ylabel('$RMSE$')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "YPREDICT = simple_model.predict(DATA[real_feature])\n",
    "Y_predict_test = simple_model.predict(X_test)\n",
    "ERRORS = (YPREDICT - DATA[TARGET]).map(np.abs)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plot_the_prediction_line(YPREDICT, Y_predict_test, 'RandomForestRegressor')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plot_the_errors(ERRORS,'RandomForestRegressor')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "ERRORS[ERRORS > 0.35]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "source": [
    "There is a big variety of regression methods available in scikit-learn package.\n",
    "[See the documentation](https://scikit-learn.org/stable/supervised_learning.html#supervised-learninghttps://scikit-learn.org/stable/supervised_learning.html#supervised-learning)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    },
    "tags": []
   },
   "source": [
    "# Feature Selection"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Random Forest + selectkbest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Selector = SelectKBest(mutual_info_regression, k=10)\n",
    "Selector.fit(X_train[real_feature], Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model = RandomForestRegressor()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "np.array(real_feature)[Selector.get_support()]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simple_model.fit(X_train[np.array(real_feature)[Selector.get_support()]], Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Y_predict = simple_model.predict(X_train[np.array(real_feature)[Selector.get_support()]])\n",
    "\n",
    "mses['simplekbest'] = {'train': mean_squared_error(Y_train, Y_predict, squared=False)}\n",
    "\n",
    "Y_test_predict = simple_model.predict(X_test[np.array(real_feature)[Selector.get_support()]])\n",
    "\n",
    "mses['simplekbest'].update({'test': mean_squared_error(Y_test, Y_test_predict,squared=False)})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### on a pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RF_SelectKbest = Pipeline(\n",
    "    [\n",
    "        ('feature_selection', SelectKBest()),\n",
    "        ('regression', RandomForestRegressor())\n",
    "    ]\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RF_SelectKbest.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Y_predict_Pipe  = RF_SelectKbest.predict(X_train)\n",
    "\n",
    "mses['RF_SK_Pipe'] = {'train': mean_squared_error(Y_train, Y_predict_Pipe, squared=False) }\n",
    "\n",
    "Y_test_predict_Pipe = RF_SelectKbest.predict(X_test)\n",
    "\n",
    "mses['RF_SK_Pipe'].update({'test': mean_squared_error(Y_test, Y_test_predict_Pipe, squared=False)})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "np.array(real_feature)[RF_SelectKbest[0].get_support()]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### with cross validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Params= {'feature_selection__k':np.arange(5,15), 'regression__max_depth':[20]} #,1, 2,3,4,5,6,7,8,9]} #, 'regression__alpha':[0.01, 0.1,1]}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Validator = GridSearchCV(RF_SelectKbest,Params, refit=True, scoring='neg_root_mean_squared_error',verbose=2,n_jobs=2,)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Validator.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Validator.best_estimator_"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fitted_best_estimator = Validator.best_estimator_.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "x = Validator.cv_results_['param_feature_selection__k'].data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y = Validator.cv_results_['mean_test_score']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.plot(x,-y)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "np.array(real_feature)[Validator.best_estimator_[0].get_support()]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## just in a loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RF_SelectKbest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "for k in range(10,20):\n",
    "#    model = Pipeline([\n",
    "#        ('feature_selection', SelectKBest(k=k)),\n",
    "#        ('regression', RandomForestRegressor(max_depth=20))\n",
    "#    ])\n",
    "    Params = {'feature_selection__k': [k]}\n",
    "    model = GridSearchCV(RF_SelectKbest,param_grid=Params,scoring='neg_root_mean_squared_error')\n",
    "    model.fit(X_train, Y_train)\n",
    "    mask = model.best_estimator_[0].get_support()\n",
    "    importances = model.best_estimator_[1].feature_importances_\n",
    "    print(k, np.array(real_feature)[mask][:3], importances, model.cv_results_['mean_test_score'])\n",
    "#    print(k, real_feature[model[0].get_support()])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Y_test_predict = fitted_best_estimator.predict(X_test)\n",
    "\n",
    "Y_train_predict = fitted_best_estimator.predict(X_train)\n",
    "\n",
    "mses['RF_SK_pipe'] ={'test':mean_squared_error(Y_test, Y_test_predict,squared=False)}\n",
    "\n",
    "mses['RF_SK_pipe'].update({'train':mean_squared_error(Y_train, Y_train_predict, squared=False)})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Ranod Forest + Sequential Selection"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "This is the same as the FeatureConcatenation I implemented, but the output doesnt tell which feature is most important and doesnt let you fix any feature"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SeqSelector = SequentialFeatureSelector(\n",
    "    RandomForestRegressor(),\n",
    "    n_features_to_select=10, n_jobs=3, \n",
    "    scoring='neg_root_mean_squared_error')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SeqSelector.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SeqSelector"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train.columns[SeqSelector.get_support()]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "features = X_train.columns[SeqSelector.get_support()]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "allfeatures = features.append( pd.Index(['MagConfig_0']))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "allfeatures"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = RandomForestRegressor(max_depth=20)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model.fit(X_train[allfeatures], Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses['RF_After_SeqSelection'] = {\n",
    "    'test': mean_squared_error(Y_test, model.predict(X_test[allfeatures]),squared=False),\n",
    "    'train': mean_squared_error(Y_train, model.predict(X_train[allfeatures]),squared=False),\n",
    "    'features_selected': allfeatures, 'importances_selected' : model.feature_importances_\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mses"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with open('mses.pkl','wb') as f:\n",
    "    pickle.dump(mses,f)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model.feature_importances_"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots()\n",
    "ax.plot( model.feature_importances_, allfeatures,)\n",
    "labels = ax.get_xticklabels()\n",
    "ax.grid('on')\n",
    "#ax.set_xticklabels(labels, rotation=90)\n",
    "#fig.tight_layout()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Random Forest + recursive feature elumination with CV"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Selector = RFECV (RandomForestRegressor(), min_features_to_select=10, \n",
    "                 scoring='neg_root_mean_squared_error', verbose=5, n_jobs=3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Selector.fit(X_train, Y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import joblib"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "joblib.dump(Selector, 'SelectorRFECV')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Selector.support_"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Selector.grid_scores_"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thisfeatures = X_train.columns[Selector.support_]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "order = np.argsort(Selector.estimator_.feature_importances_)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thisfeatures[order]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.plot(Selector.estimator_.feature_importances_[order], thisfeatures[order])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# My Old Feature Concatenation "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "# This is the standard way to import modules\n",
    "del FeatureConcatenate\n",
    "# from BopFoxFeaturizer.FeatureConcatenate import FeatureConcatenate\n",
    "FeatureConcatenate = SourceFileLoader('FeatureConcate','/home/storage/fortimtb/CuadernoTrabajo/bopfoxfeaturizer/BopFoxFeaturizer/FeatureConcatenate.py'\n",
    "                                     ).load_module().FeatureConcatenate\n",
    "\n",
    "#param_grid = {'max_depth':np.arange(1,10) , 'min_samples_split':[2]}\n",
    "param_grid = {}\n",
    "FC['RandomForest'] = FeatureConcatenate(\n",
    "    #pd.concat([X_train, Y_train['EF']], axis=1), #DATA, \n",
    "    DATA[real_feature+[TARGET]],\n",
    "    RandomForestRegressor(),\n",
    "    model_params=param_grid,\n",
    "    feature_list=real_feature,\n",
    "    data_target=TARGET,\n",
    "    criterion = C_RITERION,\n",
    "    sort_criteria='score_only'\n",
    "#    sample_weights = w_train, #Classes['Weights']\n",
    ")\n",
    "\n",
    "Bestfeats['RandomForest'], Bestscores['RandomForest'] = FC['RandomForest'].build_features_list(\n",
    "    best_feature_proposal=['MagConfig_0'],  #,'NSC_U_bind_0'],\n",
    "    maxnumfeatures=10,\n",
    "    pass_force_refit=True,\n",
    "    report_prefix='RandomForest_'+CASE\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "FileNames = SourceFileLoader('FileNames','Tools.py').load_module().CaseNamer(CASE, MODEL, CUTOFF=CUT_OFF, EMODE=E_MODE, CRITERION=C_RITERION, SEARCHMODE=SEARCH_MODE,TARGET=TARGET)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thisdata = pd.DataFrame(np.array([[x, y] for x, y in zip(Bestfeats['RandomForest'], Bestscores['RandomForest'])]))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thisdata.to_csv(\n",
    "    FileNames.get_table_filename('BopFeatures_Ubind',FC['RandomForest'].sort_criteria),\n",
    "    header=False, index=False\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "#param_grid = {'max_depth':np.arange(1,10) , 'min_samples_split':[2]}\n",
    "param_grid = {}\n",
    "del FeatureConcatenate\n",
    "FeatureConcatenate = SourceFileLoader('FeatureConcate','/home/storage/fortimtb/CuadernoTrabajo/bopfoxfeaturizer/BopFoxFeaturizer/FeatureConcatenate.py'\n",
    "                                     ).load_module().FeatureConcatenate\n",
    "\n",
    "\n",
    "FC['RandomForest_an'] = FeatureConcatenate(\n",
    "    pd.concat([X_train, Y_train], axis=1), #DATA, \n",
    "    RandomForestRegressor(),\n",
    "    model_params=param_grid,\n",
    "    feature_list=[f for f in real_feature if 'an' in f or 'bn' in f],\n",
    "    data_target=TARGET,\n",
    "    criterion = criterion\n",
    "#    sample_weights = w_train, #Classes['Weights']\n",
    ")\n",
    "\n",
    "Bestfeats['RandomForest_an'], Bestscores['RandomForest_an'] = \\\n",
    "    FC['RandomForest_an'].build_features_list(\n",
    "    best_feature_proposal=['MagConfig_0'],\n",
    "    pass_force_refit=True,\n",
    "    report_prefix='RandomForest_an_'+CASE,\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
