    "colors = {'Canonical BOP': 'Blues',  'Projections BOP': 'greens', 'Projections OS BOP': ['green', 'ocean']}\n",
    "fix, axes = plt.subplots(len(fractions), 1, figsize = (10, 15), sharex=True)\n",
    "for ax, (ds, groups ) in zip(axes, dfRMSE.groupby(level=0)):\n",
