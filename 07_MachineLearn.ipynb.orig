  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# incremental simple model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def incremental_learn (columnsgroup):\n",
    "    incremental_score = [] \n",
    "    progress = tqdm_notebook(range(0,len(columnsgroup)))\n",
    "    for max_index in progress:\n",
    "        incremental_model = RandomForestRegressor()\n",
    "        all_features = np.hstack((['MagConfig_0','NSC_U_bind_0'], np.ravel(columnsgroup[:max_index])))#  + list(columns_bn[:max_index])\n",
    "        feature_group = all_features\n",
    "        this_feature_list = feature_group\n",
    "        THHEX =DATA[feature_group].loc[X_train.index]\n",
    "        incremental_model.fit(THHEX , Y_train)\n",
    "        Ytrain_predict = incremental_model.predict(THHEX)\n",
    "        Ytest_predict = incremental_model.predict(DATA[feature_group].loc[X_test.index])\n",
    "        incremental_score.append(mean_squared_error(Y_test, Ytest_predict, squared=False))\n",
    "    return incremental_score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cols_an_bn = [[an, bn] for an, bn in zip(columns_an, columns_bn) ]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "incremental_score_moments = incremental_learn(columns_moments)\n",
    "np.savetxt(FileNames.get_table_filename('incremental_score','moments'),incremental_score_moments)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "incremental_score_an = incremental_learn(cols_an_bn)\n",
    "np.savetxt(FileNames.get_table_filename('incremental_score','an'),incremental_score_an)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "incremental_score_sigmas = incremental_learn(columns_sigma)\n",
    "np.savetxt(FileNames.get_table_filename('incremental_score','sigmas'),incremental_score_sigmas)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from matplotlib.ticker import FormatStrFormatter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thex = np.linspace(1,len(incremental_score_moments), len(incremental_score_moments))\n",
    "fig, ax = plt.subplots()\n",
    "ax.plot(thex, incremental_score_an[:-1],'--o', label = ('$(a_n,b_n)$'))\n",
    "ax.plot(thex , incremental_score_moments,'--o', label ='$m_n$')\n",
    "ax.plot(thex, incremental_score_sigmas,'--o', label = '$\\sigma _n$')\n",
    "ax.plot(thex[:len(Bestscores['RandomForest'])], Bestscores['RandomForest'], '--o', label = 'Feature Selection')\n",
    "ax.legend()\n",
    "ax.set_xlabel('n features')\n",
    "ax.tick_params(axis='y',)\n",
    "ax.set_xticks(thex)\n",
    "ax.yaxis.set_major_formatter(FormatStrFormatter('%0.3f'))\n",
    "ax.set_ylabel(f'RMSE ({criterion})')\n",
    "#ax.set_ylim([0.05,0.07])\n",
    "fig.savefig(FileNames.get_plot_filename('OrthogonalFeatures','1stMagconfig'))"
   ]
  },
