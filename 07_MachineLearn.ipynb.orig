  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [],
   "source": [
    "resultslocation = load_results_location(dataset)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Random Forest regressor "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "groups = {'moments':'^moments_.*0$|Mag|Struc','normed_moments':'^normed.*0$|Mag|Struc', 'recursion coeficients':'an_.*0$|bn_.*0$|Mag|Struc', \n",
    "         'sigmas':'sigma.*_0|Mag|Struc'}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "simplebopresultslocation = os.path.join(resultslocation, 'simpleresults.pkl')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RMSE = {}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "if os.path.exists (simplebopresultslocation):\n",
    "    dfRMSE  = pd.read_pickle(simplebopresultslocation)\n",
    "else:\n",
    "    ## BOP, full dataset\n",
    "    \n",
    "    for (group, regex), (featurename, features) in product(groups.items(), Features.items()):\n",
    "        if 'BOP' not in featurename:\n",
    "            continue\n",
    "        if (featurename, group) in RMSE.keys():\n",
    "            continue\n",
    "        X = features.filter(regex=regex).dropna()\n",
    "        model = RandomForestRegressor(random_state=42, max_depth = 20)\n",
    "        xtrain, xtest, ytrain, ytest = train_test_split(X, BS['EF'][X.index], random_state=42)\n",
    "        model.fit(xtrain, ytrain)\n",
    "        RMSE[('full', featurename, group)] = score_fitted_model(model, xtrain, xtest, ytrain, ytest)\n",
    "\n",
    "    ## BOP on FM samples\n",
    "\n",
    "    for (group, regex), (featurename, features) in product(groups.items(), Features.items()):\n",
    "        if 'BOP' not in featurename:\n",
    "            continue\n",
    "        if ('FM', featurename, group) in RMSE.keys():\n",
    "            continue\n",
    "        X = features[features['Mag']==0].filter(regex=regex).dropna()\n",
    "        model = RandomForestRegressor(random_state=42, max_depth = 20)\n",
    "        xtrain, xtest, ytrain, ytest = train_test_split(X, BS['EF'][X.index], random_state=42)\n",
    "        model.fit(xtrain, ytrain)\n",
    "        RMSE[('FM', featurename, group)] = score_fitted_model(model, xtrain, xtest, ytrain, ytest)\n",
    "\n",
    "    ## BOP on nonmagnetic samples\n",
    "\n",
    "    for (group, regex), (featurename, features) in product(groups.items(), Features.items()):\n",
    "        if 'BOP' not in featurename:\n",
    "            continue\n",
    "        if (featurename+'NM', group) in RMSE.keys():\n",
    "            continue\n",
    "        X = features[features['Mag']==1].filter(regex=regex).dropna()\n",
    "        model = RandomForestRegressor(random_state=42, max_depth = 20)\n",
    "        xtrain, xtest, ytrain, ytest = train_test_split(X, BS['EF'][X.index], random_state=42)\n",
    "        model.fit(xtrain, ytrain)\n",
    "        RMSE[('NM', featurename, group)] = score_fitted_model(model, xtrain, xtest, ytrain, ytest)\n",
    "\n",
    "    dfRMSE = pd.DataFrame.from_dict(RMSE, orient='index').sort_values(by='test')\n",
    "    dfRMSE.to_pickle(simplebopresultslocation)"
   ]
  },
