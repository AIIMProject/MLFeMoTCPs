   "source": [
    "# Machine Learning "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [],
   "source": [
    "from Tools.DatasetTools.MLConveniences import *"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "tags": []
   },
   "source": [
    "## Feature files"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [],
   "source": [
    "Features  = load_features(dataset) #{name: pd.read_pickle(filename) for name, filename in DescriptorFileList.items()}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Include magnetic feature with all BOP features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [],
   "source": [
    "Features.update({model: pd.concat([Features['dataset'][['Mag']], feature], axis=1) for model, feature in Features.items() if 'BOP' in model and 'Mag' not in feature.columns})"
   ]
  },
