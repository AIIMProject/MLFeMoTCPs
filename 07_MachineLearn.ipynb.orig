   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "slideshow": {
     "slide_type": "subslide"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "def plot_learning_curve(thescores, thefeatures, ax=None, modelname='RandomForest',dothelabels = True):\n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots()\n",
    "    ax.plot(np.arange(1,len(thescores)+1),thescores) \n",
    "    ax.set_ylabel (\"RMSE \"+C_RITERION)\n",
    "    ax.set_xlabel (\"number of features\")\n",
    "    if dothelabels:\n",
    "        for i, feat in enumerate(thefeatures):\n",
    "            t = plt.annotate(\n",
    "                feature_titles[feat],\n",
    "                ((i+1), thescores[i]),\n",
    "                ((i+1), thescores[i]),\n",
    "                fontsize=22,\n",
    "            )\n",
    "            t.set_bbox(dict(facecolor='white', alpha=0.5))\n",
    "\n",
    "    plt.savefig(FileNames.get_plot_filename('LearningCurve', modelname))\n",
    "    return ax"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
