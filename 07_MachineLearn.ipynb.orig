  {
   "cell_type": "code",
   "execution_count": 23,
   "metadata": {},
   "outputs": [],
   "source": [
    "names = gridsearch[thisexample].best_estimator_['regressor'].feature_names_in_"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "metadata": {},
   "outputs": [],
   "source": [
    "sorter = np.argsort(importances)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "metadata": {},
   "outputs": [],
   "source": [
    "best_score = {'test':{}, 'train':{}}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "metadata": {},
   "outputs": [],
   "source": [
    "%store -r best_score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "b85e2487da3f4319a38ffbe5ccda15a5",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "  0%|          | 0/476 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "progress = tqdm(range(Features[thisexample[1]].shape[1]))\n",
    "for nbest in progress:\n",
    "    if nbest in best_score['test'].keys():\n",
    "        continue\n",
    "    X = Features[thisexample[1]][names[sorter][-nbest:]]\n",
    "    Y = BS['EF']\n",
    "    xtrain, xtest, ytrain, ytest = train_test_split(X, Y, test_size=0.2, shuffle=True, random_state=42)\n",
    "    gridsearch_onbest = GridSearchCV(models[thisexample[0]], param_grid=params[thisexample[0]], scoring='neg_root_mean_squared_error')\n",
    "    gridsearch_onbest.fit(X, Y)\n",
    "    Ypredict_train = gridsearch_onbest.predict(xtrain)\n",
    "    Ypredict_test = gridsearch_onbest.predict(xtest)\n",
    "    best_score['test'].update({nbest: mean_squared_error(ytest,Ypredict_test )})\n",
    "    best_score['train'].update({nbest: mean_squared_error(ytrain,Ypredict_train )})\n",
    "    line1.set_ydata(list(best_score['test'].values()))\n",
    "    line1.set_xdata(list(best_score['test'].keys()))\n",
    "    \n",
    "    "
   ]
  },
