  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Recursivity"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "recursivity_results_location = os.path.join(resultslocation, 'recursivity.pkl' )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = RandomForestRegressor(random_state=42, max_depth = 20)\n",
    "RMSE_recursive = {}\n",
    "N0S = [0,1,2,3,4]# , 5,6]\n",
    "\n",
    "lines = {'Canonical BOP':'red', 'Projections BOP':'blue', 'Projections OS BOP':'green'}\n",
    "markers = {0: 'o', 1: 's', 2:'d', 3:'^', 4:'+', 5:'P', 6:'*'}\n",
    "\n",
    "groups = { 'recursion coeficients':'an_.*0$|bn_.*0$', 'moments':'^moments_.*0$','normed_moments':'^normed.*0$',\n",
    "         'sigmas':'sigma.*_0'}\n",
    "symbols = { 'recursion coeficients':r'$\\langle a_n \\rangle$ , $ \\langle b_n \\rangle$',\n",
    "            'moments':r'$ \\langle \\mu_n \\rangle$',\n",
    "           'normed_moments':r'$ \\langle \\hat{\\mu}_n \\rangle$',\n",
    "         'sigmas':r'$ \\langle \\sigma_n \\rangle$'}\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from matplotlib.lines import Line2D"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "<<<<<<< local\n"
     ]
    },
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "4b8b1ed5625d44f988891c4c1b2dde5f",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "  0%|          | 0/120 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "=======\n"
     ]
    },
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "2d8d34c965d347cfaaf37e135b37e50f",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "  0%|          | 0/120 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      ">>>>>>> remote\n"
     ]
    }
   ],
   "source": [
    "if True: #not os.path.exists(recursivity_results_location):\n",
    "    progress = tqdm(list(product(groups.items(), Features.items(), N0S)))\n",
    "    for (group, regex), (featurename, features), N0 in progress: #product(groups.items(), Features.items(), N0S):\n",
    "        if 'BOP' not in featurename:\n",
    "            continue\n",
    "        #thisfeatures = features.filter(regex=regex)\n",
    "        if 'recursion' in group:\n",
    "            XA = features.filter(regex='an_.*_0')\n",
    "            XB = features.filter(regex='bn_.*_0')\n",
    "        else:\n",
    "            XA = features.filter(regex=regex)\n",
    "        N = XA.shape[1]\n",
    "        progress.set_description(f'{featurename}, {group}, {N}')\n",
    "        for o in range(N0, N):\n",
    "            if (featurename, group, N0) in RMSE_recursive.keys():\n",
    "                continue\n",
    "            if 'recursion' in group:\n",
    "                X = pd.concat([features['Mag'], XA[XA.columns[N0:o+1]],XB[XB.columns[N0:o+1]] ], axis=1 )\n",
    "                order = 2*o +1\n",
    "            else:\n",
    "    #            X = features.filter(regex=regex)\n",
    "                X = pd.concat([features['Mag'], XA[XA.columns[N0:o+1]]], axis = 1)\n",
    "                order = o+1\n",
    "            tX = X.dropna()\n",
    "            xtrain, xtest, ytrain, ytest = train_test_split(tX , BS['EF'][tX.index], random_state=42)\n",
    "            model.fit(xtrain, ytrain)\n",
    "            RMSE_recursive[(featurename, group, N0, order+1)] = score_fitted_model(model, xtrain, xtest, ytrain, ytest)\n",
    "\n",
    "    dfRMSE_recursive = pd.DataFrame.from_dict(RMSE_recursive, orient='index').sort_index()#.sort_values(by='test')\n",
    "    dfRMSE_recursive.to_pickle(recursivity_results_location)\n",
    "else:\n",
    "    dfRMSE_recursive = pd.read_pickle(recursivity_results_location)"
   ]
  },
