   "source": [
    "# Test for overfitting "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "metadata": {},
   "outputs": [],
   "source": [
    "thisexample = ('Decision Tree Regressor', 'Projections BOP')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [],
   "source": [
    "importances = gridsearch[thisexample].best_estimator_['regressor'].feature_importances_"
   ]
