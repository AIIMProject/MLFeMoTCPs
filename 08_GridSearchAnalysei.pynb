   "id": "6f592159-ae1f-40b1-b76f-950d2442503a",
   "metadata": {},
   "outputs": [],
   "source": [
    "thistrainedmodel = gridsearch[('Decision Tree Regressor', 'Canonical BOP')]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "163864c8-41ae-4331-be90-1e93adf7044d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_all_prediction_lines (model):\n",
    "    for (featurename, features_train)  in Features_train.items():\n",
    "        thistrainedmodel = gridsearch[(model, featurename)]\n",
    "        if 'BOP' in featurename:\n",
    "            predict_train = thistrainedmodel.predict(features_train.filter(regex='.*_0'))\n",
    "            predict_test = thistrainedmodel.predict(Features_test[featurename].filter(regex='.*_0'))\n",
    "        else:\n",
    "            predict_train = thistrainedmodel.predict(features_train)\n",
    "            predict_test = thistrainedmodel.predict(Features_test[featurename])\n",
    "        print(model, featurename)\n",
    "        error_train = (Target_train - predict_train).abs()\n",
    "        error_test = (Target_test - predict_test).abs()\n",
    "        fig, ax = plt.subplots(1,2, figsize=(15,6))\n",
    "        sns.histplot(error_train, ax= ax[0],label='train')\n",
    "        sns.histplot(error_test, ax=ax[0],color='orange', label='test')\n",
    "        ax[0].set_xlabel(r'test error on $\\Delta E_f$')\n",
    "        sns.scatterplot(x=predict_train, y = Target_train, ax = ax[1], label='train')#, c=error_train)\n",
    "        sns.scatterplot(x=predict_test, y = Target_test, ax = ax[1], label='test')# , c=error_test)\n",
    "        x = Target_train.sort_values()\n",
    "        sns.lineplot(x = x, y =x, ax=ax[1], color='k', label='$y = x$')\n",
    "        ax[1].set_ylabel(r'True values $\\Delta E_f$')\n",
    "        ax[1].set_xlabel(r'Predicted values $\\Delta E_f$')\n",
    "        ax[1].legend()\n",
    "        fig.suptitle(f'Decision Tree Regressor on {featurename} features')\n",
    "        fig.tight_layout()"
   ]
  },
