{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "37057eef-cc7c-43c1-8d48-1addf2aa0c7b",
   "metadata": {},
   "source": [
    "# Anlisis of Grid Search Cross Validation "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "dc22a658-4afb-4469-81c7-e36e281cb473",
   "metadata": {},
   "outputs": [],
   "source": [
    "from Tools.DatasetTools.Commoms import *\n",
    "from Tools.DatasetTools.MLConveniences import *"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "40c03461-f12d-471d-8c65-dbff054d7d3b",
   "metadata": {},
   "outputs": [],
   "source": [
    "dataset = 'Fe-Mo'\n",
    "gridsearchlocation = os.path.join(dataset, 'results', 'GridSearchResults.pkl')\n",
    "samplesplitlocation = os.path.join(dataset, 'samplesplit.pkl')\n",
    "with open(gridsearchlocation, 'rb') as pkl:\n",
    "    gridsearch = pickle.load(pkl)\n",
    "with open(samplesplitlocation, 'rb') as pkl:\n",
    "    samplesplit = pickle.load(pkl)\n",
    "BS = load_fully_curated_briefsummary(dataset)\n",
    "Features = load_features(dataset)\n",
    "Features_test = {name: features.loc[samplesplit['test']] for name, features in Features.items()}\n",
    "Features_train = {name: features.loc[samplesplit['train']] for name, features in Features.items()}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1052949b-0809-4fc1-bf2e-701aa8ca3260",
   "metadata": {},
   "source": [
    "## concatenated with mag"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "358314a0-efe6-49ef-b544-ef0e91617921",
   "metadata": {},
   "outputs": [],
   "source": [
    "def add_mag(name, features:pd.core.frame.DataFrame, part:str):\n",
    "    if 'Mag' not in features.columns:\n",
    "        return pd.concat([Features['dataset']['Mag'][samplesplit[part]], features], axis=1)\n",
    "    else:\n",
    "        return features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "3bee5ce1-1dbd-4b29-be68-2cfbe06dbdfd",
   "metadata": {},
   "outputs": [],
   "source": [
    "Features_test.update(  {name: add_mag(name,features,'test') for name, features in Features_test.items()})\n",
    "Features_train.update(  {name: add_mag(name,features,'train') for name, features in Features_train.items()})"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "88af8341-7cf0-4871-9895-82957d0f9bc5",
   "metadata": {},
   "source": [
    "## and concatenate dataset to bop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "ea2a9035-1394-4ffe-aa5c-efffba9f3a34",
   "metadata": {},
   "outputs": [],
   "source": [
    "def add_dataset(name, features:pd.core.frame.DataFrame, part:str):\n",
    "    if 'BOP' in name and len(features.columns.intersection(Features['dataset'].columns)) < 2:\n",
    "        X = Features['dataset'].loc[samplesplit[part]].drop(columns=['Mag'])\n",
    "        return pd.concat([X, features], axis=1)\n",
    "    else:\n",
    "        return features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "1e067bc7-ea75-4258-bc4d-71894debecb8",
   "metadata": {},
   "outputs": [],
   "source": [
    "Features_test.update(  {'dataset + '+name: add_dataset(name,features,'test') for name, features in Features_test.items() if 'BOP' in name} )\n",
    "Features_train.update(  {'dataset + '+name: add_dataset(name,features,'train') for name, features in Features_train.items() if 'BOP' in name})"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1701b0ef-f357-438f-ae84-3204076dabd9",
